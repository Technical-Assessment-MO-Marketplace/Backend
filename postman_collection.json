                "attributes"
              ]
            },
            "description": "Get all available attributes for filtering a product's variants. No authentication required."
          },
          "response": []
        },
        {
          "name": "Filter Product Variants",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attributeValueIds\": [1, 3]\n}"
            },
            "url": {
              "raw": "{{base_url}}/products/1/variants/filter",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "1",
                "variants",
                "filter"
              ]
            },
            "description": "Filter variants by selected attribute values. No authentication required."
          },
          "response": []
        }
      ]
