          "response": []
        },
        {
          "name": "Get Product Attributes (for filtering)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products/1/attributes",
              "host": [
                "{{base_url}}"
